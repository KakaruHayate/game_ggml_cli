+// --- MTLBinaryArchive PSO cache ---
+// Caches compiled pipeline state objects to disk so subsequent launches skip
+// the expensive newComputePipelineState compilation.
+
+static NSURL * ggml_metal_archive_url(void) {
+    const char * env = getenv("GGML_METAL_ARCHIVE_PATH");
+    if (env && env[0]) {
+        return [NSURL fileURLWithPath:[NSString stringWithUTF8String:env]];
+    }
+    NSString * home = NSHomeDirectory();
+    NSString * dir = [home stringByAppendingPathComponent:@".cache/ggml"];
+    [[NSFileManager defaultManager] createDirectoryAtPath:dir withIntermediateDirectories:YES attributes:nil error:nil];
+    return [NSURL fileURLWithPath:[dir stringByAppendingPathComponent:@"pipelines.metallib"]];
+}
+
+static id<MTLBinaryArchive> ggml_metal_archive_load(id<MTLDevice> device) {
+    NSURL * url = ggml_metal_archive_url();
+    MTLBinaryArchiveDescriptor * desc = [MTLBinaryArchiveDescriptor new];
+    if ([[NSFileManager defaultManager] isReadableFileAtPath:[url path]]) {
+        desc.url = url;
+    }
+    NSError * error = nil;
+    id<MTLBinaryArchive> archive = [device newBinaryArchiveWithDescriptor:desc error:&error];
+#if !__has_feature(objc_arc)
+    [desc release];
+#endif
+    if (!archive) {
+        GGML_LOG_WARN("%s: failed to load binary archive: %s\n", __func__,
+                      error ? [[error description] UTF8String] : "unknown");
+    } else {
+        GGML_LOG_INFO("%s: loaded Metal binary archive from '%s'\n", __func__, [[url path] UTF8String]);
+    }
+    return archive;
+}
+
+static void ggml_metal_archive_save(id<MTLBinaryArchive> archive) {
+    if (!archive) return;
+    NSURL * url = ggml_metal_archive_url();
+    NSError * error = nil;
+    if (![archive serializeToURL:url error:&error]) {
+        GGML_LOG_WARN("%s: failed to save binary archive: %s\n", __func__,
+                      error ? [[error description] UTF8String] : "unknown");
+    } else {
+        GGML_LOG_INFO("%s: saved Metal binary archive to '%s'\n", __func__, [[url path] UTF8String]);
+    }
+}
+
